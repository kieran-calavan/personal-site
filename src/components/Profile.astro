---
---

<div class="flex flex-col items-center text-center space-y-4 lg:space-y-6 animate-fade-up">
  <div class="rounded-2xl p-0.5 gradient-bg [box-shadow:0_0_50px_rgba(143,173,154,0.35)]">
    <img
      src="/kieran-color.jpeg"
      alt="Kieran Calavan"
      class="w-48 h-48 lg:w-72 lg:h-72 rounded-2xl object-cover"
    />
  </div>
  <div class="flex flex-col space-y-4 lg:space-y-6">
    <p id="role-el" class="font-mono text-xs lg:text-sm tracking-[0.25em] uppercase text-[#8fad9a]/80 opacity-0 translate-y-4 transition-[opacity,transform] duration-700">Web Developer</p>
    <h1 id="name-el" class="font-serif text-4xl lg:text-6xl font-medium tracking-tight text-zinc-50 opacity-0 translate-y-4 transition-[opacity,transform] duration-700">Kieran Calavan</h1>
    <div id="location-el" class="flex items-center justify-center gap-2 font-mono text-sm lg:text-md text-zinc-500 opacity-0 translate-y-4 transition-[opacity,transform] duration-700">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-[#8fad9a] [animation:dotPulse_2s_ease-in-out_infinite]"></span>
      <span>Saint Paul, MN</span>
    </div>
    <p id="bio-el" class="font-jetbrains text-sm text-zinc-400 max-w-md leading-relaxed opacity-0 translate-y-4 transition-[opacity,transform] duration-700">
      Web developer with 4+ years experience turning designs into production-ready sites across agency and client projects.
      <br/><br/>Currently @ <a href="https://thatsnice.com" target="_blank" rel="noopener noreferrer" class="text-zinc-300 hover:text-[#8fad9a] transition-colors duration-200 link-underline">That's Nice</a>.
    </p>
  </div>
</div>

<script>
  const sleep = (ms: number) => new Promise(r => setTimeout(r, ms));

  const reveal = (el: HTMLElement | null) => {
    if (el) el.classList.remove('opacity-0', 'translate-y-4');
  };

  setTimeout(async () => {
    reveal(document.getElementById('role-el'));
    await sleep(150);
    reveal(document.getElementById('name-el'));
    await sleep(150);
    reveal(document.getElementById('location-el'));
    await sleep(150);
    reveal(document.getElementById('bio-el'));
    await sleep(200);
    reveal(document.getElementById('social-links'));
  }, 300);
</script>
