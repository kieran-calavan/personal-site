---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  ['email', 'mailto:kieran.calavan@gmail.com'],
  ['github', 'https://github.com/kieran-calavan/'],
  ['linkedin', 'https://linkedin.com/in/kieran-calavan/'],
];
const details = [
  ['role', 'web developer'],
  ['based', 'saint paul, mn'],
  ['exp', '4+ years'],
];
const builds = [
  ['trade automate', 'https://trade-automate.com/', 'Booking, scheduling & automation platform built for trades businesses.'],
  ['cycle tracker', 'https://cycle-tracker-app-five.vercel.app/', 'Period & cycle tracking app with predictions and logging.'],
];
---

<BaseLayout>
  <main class="min-h-[100dvh] w-full max-w-[1200px] mx-auto px-6 md:px-10 flex flex-col justify-center py-10 lg:py-20">
    <!-- masthead -->
    <header class="rise flex items-end justify-between gap-6 border-b border-zinc-700 pb-6" style="animation-delay:0.05s">
      <h1 class="text-[clamp(2.5rem,10vw,8rem)] font-black tracking-tighter leading-[0.85]">
        Kieran<br />Calavan
      </h1>
      <span class="mono text-xs text-zinc-500 pb-3 shrink-0 hidden md:block">
        <span class="accent">~</span> kieran-calavan
      </span>
    </header>

    <!-- ledger -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-px bg-zinc-800 mt-px">
      <!-- profile -->
      <section class="bg-[#09090b] md:col-span-5 py-6 md:p-8">
        <div class="rise" style="animation-delay:0.18s">
          <h2 class="mono text-[11px] tracking-[0.25em] uppercase accent mb-4">profile</h2>
          <p class="mono text-sm text-zinc-300 leading-relaxed">
            <span class="accent">$</span> Web developer with 4+ years shipping production sites for agencies and clients. Always tinkering on personal builds.<span class="term-caret"></span>
          </p>
        </div>
      </section>

      <!-- details -->
      <section class="bg-[#09090b] md:col-span-3 py-6 md:p-8">
        <div class="rise flex flex-col gap-5" style="animation-delay:0.26s">
          <h2 class="mono text-[11px] tracking-[0.25em] uppercase text-zinc-500">details</h2>
          {details.map(([k, v]) => (
            <div class="mono">
              <p class="text-[11px] uppercase text-zinc-600">{k}</p>
              <p class="text-sm text-zinc-200 mt-0.5">{v}</p>
            </div>
          ))}
          <div class="mono">
            <p class="text-[11px] uppercase text-zinc-600">now</p>
            <a href="https://thatsnice.com" target="_blank" rel="noopener noreferrer"
               class="link-underline inline-block w-fit text-sm text-zinc-200 mt-0.5 hover:text-[var(--accent)] transition-colors">that's nice ↗</a>
          </div>
        </div>
      </section>

      <!-- contact -->
      <nav class="bg-[#09090b] md:col-span-4 py-6 md:p-8" aria-label="Contact links">
        <div class="rise flex flex-col gap-3.5" style="animation-delay:0.34s">
        <div class="mono flex flex-col gap-1">
          <p class="text-[11px] tracking-[0.25em] uppercase text-zinc-500 mb-1">personal projects</p>
          {builds.map(([label, href, desc], i) => {
            const words = desc.trim().split(' ');
            const last = words.pop();
            const head = words.join(' ');
            return (
            <div class="tip group w-fit">
              <div class="flex items-center gap-2">
                <a href={href} target="_blank" rel="noopener noreferrer"
                   class="link-underline inline-block w-fit text-sm text-zinc-200 group-hover:text-[var(--accent)] transition-colors">{label} ↗</a>
                <input id={`tip-${i}`} type="checkbox" class="tip-toggle sr-only md:hidden" />
                <label for={`tip-${i}`} aria-label={`Show description for ${label}`}
                       class="tip-btn md:hidden inline-flex items-center justify-center p-1.5 -m-1.5 translate-y-px text-zinc-600 cursor-pointer select-none">
                  <svg class="tip-btn-icon" width="11" height="11" viewBox="0 0 24 24" fill="none"
                       stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M6 9l6 6 6-6" />
                  </svg>
                </label>
              </div>
              <div class="tip-wrap">
                <a href={href} target="_blank" rel="noopener noreferrer"
                   class="tip-card relative block overflow-hidden border-l-2 border-l-[var(--accent)] bg-zinc-900/95 w-72 text-[11px] normal-case tracking-normal leading-snug text-zinc-300 hover:bg-zinc-800/95 hover:text-zinc-100 transition-colors">
                  <span class="tip-scan"></span>
                  <span class="accent mr-1">›</span>{head} <span class="whitespace-nowrap">{last}<span class="tip-caret"></span></span>
                </a>
              </div>
            </div>
            );
          })}
        </div>
        <h2 class="mono text-[11px] tracking-[0.25em] uppercase text-zinc-500 mb-1">contact</h2>
        {links.map(([label, href]) => (
          <a href={href} target="_blank" rel="noopener noreferrer"
             class="group mono flex items-center justify-between text-sm text-zinc-300 hover:text-[var(--accent)] transition-colors">
            <span class="link-underline">[ {label} ]</span>
            <span class="text-zinc-600 group-hover:text-[var(--accent)] group-hover:translate-x-0.5 transition-all">↗</span>
          </a>
        ))}
        </div>
      </nav>
    </div>
  </main>
</BaseLayout>

<style>
  /* mobile: collapsed; the [›] toggle reveals it. tapping the label follows the link */
  .tip-wrap {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    opacity: 0;
    transition: grid-template-rows 0.28s cubic-bezier(0.65, 0, 0.35, 1), opacity 0.18s ease;
  }
  .tip:has(.tip-toggle:checked) .tip-wrap {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  /* rotate the chevron + highlight the button when open */
  .tip-btn-icon {
    transition: transform 0.2s ease;
  }
  .tip:has(.tip-toggle:checked) .tip-btn-icon {
    transform: rotate(180deg);
  }
  .tip:has(.tip-toggle:checked) .tip-btn {
    color: var(--accent);
  }
  .tip-toggle:focus-visible + .tip-btn {
    color: var(--accent);
  }

  /* desktop: no toggle — slide open on hover instead */
  @media (min-width: 768px) {
    .tip:hover .tip-wrap,
    .tip:focus-within .tip-wrap {
      grid-template-rows: 1fr;
      opacity: 1;
    }
  }
  .tip-card {
    min-height: 0;
    margin-top: 0.6rem;
    padding: 0.5rem 0.75rem;
  }
  /* bridge the gap above the card so it's clickable + keeps hover continuous */
  .tip-card::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: -0.6rem;
    height: 0.6rem;
  }

  /* accent bar that sweeps across as the card opens */
  .tip-scan {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1.5px;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    left: 0;
    opacity: 0;
  }
  .tip:hover .tip-scan,
  .tip:focus-within .tip-scan {
    animation: tip-sweep 0.34s cubic-bezier(0.65, 0, 0.35, 1);
  }
  @keyframes tip-sweep {
    0%   { left: 0;    opacity: 1; }
    90%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }

  /* blinking block caret, revealed after the wipe lands */
  .tip-caret {
    display: inline-block;
    width: 0.5em;
    height: 1em;
    margin-left: 2px;
    vertical-align: text-bottom;
    background: var(--accent);
    opacity: 0;
  }
  .tip:hover .tip-caret,
  .tip:focus-within .tip-caret {
    animation: tip-blink 1s steps(1) 0.34s infinite;
  }
  @keyframes tip-blink {
    0%, 50%  { opacity: 1; }
    51%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tip-wrap { transition: opacity 0.15s ease; }
    .tip-scan, .tip-caret { animation: none; }
  }
</style>
